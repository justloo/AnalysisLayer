# Copy to .env and fill in to use the real model provider. With no .env the system
# defaults to the deterministic MockClient and runs fully offline.

# Which model backend the reasoning nodes use: "mock" (default), "google", or "anthropic".
ANALYSIS_LAYER_MODEL_BACKEND=mock

# Google AI Studio / Gemini Developer API (backend=google).
# Get a key at https://aistudio.google.com/apikey
# Either variable works; google-genai reads both.
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Strong tier: hypothesis generation, red team, synthesis (Section 9.2).
ANALYSIS_LAYER_STRONG_MODEL=gemini-2.5-pro
# Fast tier: per-cell consistency judgments, clustering assist (Section 9.2).
ANALYSIS_LAYER_FAST_MODEL=gemini-2.5-flash

# Legacy Anthropic provider (backend=anthropic only).
# ANTHROPIC_API_KEY=
# ANALYSIS_LAYER_STRONG_MODEL=claude-opus-4-20250514
# ANALYSIS_LAYER_FAST_MODEL=claude-3-5-haiku-20241022

# Sampling. Reasoning nodes run low-temperature; the scoreboard reports the
# distribution across repeated runs rather than a single pass (Section 7.8).
ANALYSIS_LAYER_TEMPERATURE=0.2

# Calibration store: "memory" (default) or "postgres".
ANALYSIS_LAYER_STORE_BACKEND=memory
ANALYSIS_LAYER_DATABASE_URL=postgresql://analysis:analysis@localhost:5432/analysis_layer
